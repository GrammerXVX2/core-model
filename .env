# Rename to .env and set HF_TOKEN if model requires auth
HF_TOKEN=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

# Shared images
VLLM_IMAGE=vllm/vllm-openai:latest

# Hugging Face transfer/runtime
HF_HUB_ENABLE_HF_TRANSFER=1
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Chat vLLM service (vllm-gpu0)
VLLM_CHAT_MODEL_TAG=Qwen/Qwen3.5-9B
VLLM_CHAT_VISIBLE_DEVICES=0,1
VLLM_CHAT_TP_SIZE=2
VLLM_CHAT_DTYPE=bfloat16
VLLM_CHAT_MAX_MODEL_LEN=16384
VLLM_CHAT_GPU_MEM_UTIL=0.80
VLLM_CHAT_KV_CACHE_DTYPE=fp8
VLLM_CHAT_SWAP_SPACE=8
VLLM_CHAT_MAX_NUM_SEQS=4
VLLM_CHAT_MAX_BATCHED_TOKENS=2048

# Embedding defaults (local Qwen3.5-4B removed; use remote 8B route)
VLLM_EMBED_MODEL=Qwen3-Embedding-8B
VLLM_EMBED_VISIBLE_DEVICES=0,1
VLLM_EMBED_TP_SIZE=2
VLLM_EMBED_DTYPE=half
VLLM_EMBED_MAX_MODEL_LEN=8192
VLLM_EMBED_GPU_MEM_UTIL=0.55
VLLM_EMBED_MAX_NUM_SEQS=4
VLLM_EMBED_MAX_BATCHED_TOKENS=2048

# Proxy routing and defaults
VLLM_BASE_URLS=http://vllm-gpu0:8000/v1
VLLM_MODEL=Qwen/Qwen3.5-9B
VLLM_CHAT_BASE_URL=http://vllm-gpu0:8000/v1
QWEN_CHAT_MODEL=Qwen/Qwen3.5-9B
QWEN_CHAT_BASE_URL=http://vllm-gpu0:8000/v1
MINISTRAL_CHAT_MODEL=Ministral-3-14B
MINISTRAL_CHAT_BASE_URL=http://10.77.166.156:8000/v1
VLLM_EMBED_BASE_URL=http://10.77.166.156:8001/v1
QWEN_EMBED_MODEL=Qwen3-Embedding-8B
QWEN_EMBED_BASE_URL=http://10.77.166.156:8001/v1
QWEN_EMBED_8B_MODEL=Qwen3-Embedding-8B
QWEN_EMBED_8B_BASE_URL=http://10.77.166.156:8001/v1
QWEN_EMBED_4B_MODEL=Qwen3-Embedding-4B
QWEN_EMBED_4B_BASE_URL=http://10.77.166.156:8002/v1

# Public aliases returned by proxy
PUBLIC_QWEN_CHAT_MODEL=Qwen3.5-9B
PUBLIC_QWEN_EMBED_MODEL=Qwen3-Embedding-8B
PUBLIC_QWEN_EMBED_8B_MODEL=Qwen3-Embedding-8B
PUBLIC_QWEN_EMBED_4B_MODEL=Qwen3-Embedding-4B
PUBLIC_MINISTRAL_CHAT_MODEL=Ministral3-14B

# Additional CPU chat models (kept in addition to existing routes)
CPU_CHAT_Q4_MODEL=Qwen3.5-9B-Q4_K_M
CPU_CHAT_Q4_BASE_URL=http://10.77.163.177:8101/v1
PUBLIC_CPU_CHAT_Q4_MODEL=Qwen3.5-9B-Q4_K_M
CPU_CHAT_Q4_MAX_CONTEXT_TOKENS=8192

CPU_CHAT_Q6_MODEL=Qwen3.5-9B-Q6_K
CPU_CHAT_Q6_BASE_URL=http://10.77.163.177:8102/v1
PUBLIC_CPU_CHAT_Q6_MODEL=Qwen3.5-9B-Q6_K
CPU_CHAT_Q6_MAX_CONTEXT_TOKENS=8192

# Proxy generation/token controls
DEFAULT_RESPONSE_LANGUAGE=ru
DISABLE_THINKING=1
VLLM_DEFAULT_MAX_TOKENS=512
VLLM_MAX_TOKENS_CAP=1024
VLLM_MAX_CONTEXT_TOKENS=10240
VLLM_MIN_CONTEXT_HEADROOM=256
PROXY_PORT=11434
UPSTREAM_TIMEOUT_SECONDS=10
MODEL_STATUS_POLL_INTERVAL_SECONDS=60

# Per-model context shown in /api/models
QWEN_CHAT_MAX_CONTEXT_TOKENS=10240
QWEN_EMBED_MAX_CONTEXT_TOKENS=8192
QWEN_EMBED_8B_MAX_CONTEXT_TOKENS=8192
QWEN_EMBED_4B_MAX_CONTEXT_TOKENS=4096
MINISTRAL_CHAT_MAX_CONTEXT_TOKENS=8192
